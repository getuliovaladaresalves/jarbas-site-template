# === Database ===
DATABASE_URI=postgresql://user:password@localhost:5432/site_db
# Para MongoDB: mongodb://localhost:27017/site_db

# === Payload CMS ===
PAYLOAD_SECRET=CHANGE_ME_TO_RANDOM_SECRET_MIN_32_CHARS

# === Site ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Armazenamento (produção) ===
# BLOB_READ_WRITE_TOKEN=vercel_blob_token_here
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# === SEO & Analytics (configurável via admin /admin) ===
# Os valores abaixo também podem ser configurados via painel admin > SEO Settings
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# === Pagamentos (preset ecommerce) ===
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# === Migração WordPress ===
# WP_URL=https://seu-site-wordpress.com.br
# WP_NONCE=nonce_para_api_autenticada
