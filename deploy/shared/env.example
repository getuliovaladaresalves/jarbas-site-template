# === Database ===
# Dev local: SQLite (padrão, zero configuração)
# DATABASE_URI=file:./data/dev.db

# Produção: PostgreSQL gerenciado pelo Coolify
# Copie a connection string interna gerada pelo Coolify
DATABASE_URI=postgresql://user:password@localhost:5432/site_db

# === Payload CMS ===
# Gere com: openssl rand -base64 32
PAYLOAD_SECRET=CHANGE_ME_TO_RANDOM_SECRET_MIN_32_CHARS

# === Site ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Armazenamento de mídia (produção) ===
# Opção A: S3 ou compatível (MinIO, Cloudflare R2, etc.)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=   # para S3-compatíveis como MinIO ou R2

# Opção B: volume local no servidor (padrão para Coolify)
# As mídias ficam em /app/public/media dentro do container
# Configure um volume persistente no Coolify para este path

# === SEO & Analytics (configurável via /admin → SEO Settings) ===
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# === Pagamentos (preset ecommerce) ===
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# === Migração WordPress ===
# WP_URL=https://seu-site-wordpress.com.br
# WP_NONCE=nonce_para_api_autenticada
